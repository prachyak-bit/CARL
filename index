    <td style="font-size:11px">${r['ระยะห่างจากโรงเรียน(ม)']||'-'} ม.</td>
    <td>${r['URL รูปภาพ']?`<a href="${r['URL รูปภาพ']}" target="_blank" class="btn btn-sm btn-outline"><i class="fas fa-image"></i></a>`:'-'}</td>
    <td>${getStatusBadge(r['สถานะ'])}</td>
    <td><button class="btn btn-sm btn-danger" onclick="deleteLog('${r['ID']}')"><i class="fas fa-trash"></i></button></td>
  </tr>`).join('');
}
function filterLogsTable() {
  const q = document.getElementById('logsSearch').value.toLowerCase();
  renderLogsTable(allLogs.filter(l => (l['ชื่อบุคลากร']||'').toLowerCase().includes(q)));
}
async function deleteLog(id) {
  if (!confirm('ยืนยันการลบ?')) return;
  const res = await api({ action: 'deleteLog', id });
  if (res.status === 'success') { toast('ลบสำเร็จ', 'success'); loadLogs(); }
  else toast('เกิดข้อผิดพลาด', 'error');
}

/* ═══════════════════════════════════════════════════════════
   STATS
═══════════════════════════════════════════════════════════ */
async function loadStats() {
  showLoading();
  const res = await api({ action: 'getStats', month: document.getElementById('statsMonth').value });
  hideLoading();
  const data = res.data||[];
  document.getElementById('statsTotal').textContent = data.length;
  if (data.length) {
    document.getElementById('statsTop').textContent = data[0].checkedIn;
    document.getElementById('statsTopName').textContent = data[0].name;
    const ti = data.reduce((s,d)=>s+d.checkedIn,0), ta = data.reduce((s,d)=>s+d.total,0);
    document.getElementById('statsRate').textContent = ta ? Math.round(ti/ta*100)+'%' : '0%';
  }
  document.getElementById('statsTableBody').innerHTML = data.map((r,i) => `<tr>
    <td><span class="badge ${i===0?'badge-warning':i===1?'badge-info':'badge-gray'}">#${i+1}</span></td>
    <td><span class="badge badge-gray">${r.id||'-'}</span></td>
    <td><b>${r.name||'-'}</b></td><td>${r.checkedIn}</td><td>${r.checkedOut}</td>
    <td><div style="display:flex;align-items:center;gap:8px">
      <div class="progress" style="flex:1;height:6px"><div class="progress-bar" style="width:${r.total?Math.round(r.checkedIn/r.total*100):0}%;background:var(--teal)"></div></div>
      <span style="font-size:12px;font-weight:700;color:var(--teal)">${r.total?Math.round(r.checkedIn/r.total*100):0}%</span>
    </div></td>
  </tr>`).join('');
  renderStatsCharts(data);
}
function renderStatsCharts(data) {
  const top10 = data.slice(0,10);
  const c1 = document.getElementById('chartStatsTop')?.getContext('2d');
  if (c1) { if(charts.st) charts.st.destroy(); charts.st = new Chart(c1,{type:'bar',data:{labels:top10.map(d=>d.name),datasets:[{label:'เข้าเวร',data:top10.map(d=>d.checkedIn),backgroundColor:'rgba(38,166,154,.75)',borderRadius:6}]},options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false}},scales:{x:{beginAtZero:true},y:{grid:{display:false}}}}}); }
  const c2 = document.getElementById('chartStatsDuty')?.getContext('2d');
  if (c2 && data.length) { if(charts.sd) charts.sd.destroy(); charts.sd = new Chart(c2,{type:'doughnut',data:{labels:['เข้าเวรแล้ว','ออกเวรครบ'],datasets:[{data:[data.reduce((s,d)=>s+d.checkedIn,0),data.reduce((s,d)=>s+d.checkedOut,0)],backgroundColor:['#26A69A','#7CB342'],borderWidth:3,borderColor:'#fff'}]},options:{responsive:true,cutout:'60%',plugins:{legend:{position:'bottom'}}}}); }
}

/* ═══════════════════════════════════════════════════════════
   TEACHERS
═══════════════════════════════════════════════════════════ */
async function loadTeachers() {
  const res = await api({ action: 'getTeachers' }); allTeachers = res.data||[];
  const tbody = document.getElementById('teachersTableBody'), noData = document.getElementById('noTeachersData');
  if (!allTeachers.length) { tbody.innerHTML = ''; noData.style.display = 'block'; return; }
  noData.style.display = 'none';
  tbody.innerHTML = allTeachers.map(t => `<tr>
    <td><span class="badge badge-gray">${t['รหัสบุคลากร']||'-'}</span></td>
    <td><b>${t['ชื่อ-นามสกุล']||'-'}</b></td><td>${t['ตำแหน่ง']||'-'}</td>
    <td>${t['วิชาเอก']||'-'}</td><td>${t['โทรศัพท์']||'-'}</td>
    <td>${t['สถานะ']==='ปกติ'?'<span class="badge badge-success">ปกติ</span>':`<span class="badge badge-danger">${t['สถานะ']}</span>`}</td>
  </tr>`).join('');
}
function showAddTeacherForm() { document.getElementById('addTeacherForm').style.display = 'block'; }
function hideAddTeacherForm() { document.getElementById('addTeacherForm').style.display = 'none'; }
async function saveTeacher() {
  const id = document.getElementById('tId').value.trim(), name = document.getElementById('tName').value.trim();
  if (!id) { toast('กรุณากรอกรหัสบุคลากร', 'error'); return; }
  if (!name) { toast('กรุณากรอกชื่อ-นามสกุล', 'error'); return; }
  showLoading('กำลังบันทึกข้อมูลบุคลากร...');
  const res = await api({ action: 'addTeacher', teacherId: id, name,
    position: document.getElementById('tPosition').value, subject: document.getElementById('tSubject').value,
    phone: document.getElementById('tPhone').value, email: document.getElementById('tEmail').value,
    lineId: document.getElementById('tLine').value, telegramId: document.getElementById('tTelegram').value });
  hideLoading();
  if (res.status === 'success') {
    toast('✅ เพิ่มบุคลากรสำเร็จ', 'success'); hideAddTeacherForm();
    ['tId','tName','tPosition','tSubject','tPhone','tEmail','tLine','tTelegram'].forEach(i => document.getElementById(i).value = '');
    loadTeachers();
  } else toast('เกิดข้อผิดพลาด: ' + (res.message||''), 'error');
}

/* ═══════════════════════════════════════════════════════════
   REPORT / EXPORT
═══════════════════════════════════════════════════════════ */
async function exportExcel() {
  showLoading('กำลังสร้างไฟล์...');
  const res = await api({ action: 'exportReport' }); hideLoading();
  if (res.status !== 'success' || !res.data?.length) { toast('ไม่มีข้อมูล', 'error'); return; }
  const ws = XLSX.utils.json_to_sheet(res.data), wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'บันทึกเวร');
  XLSX.writeFile(wb, `รายงานบุคลากรเวร_${todayStr()}.xlsx`);
  toast('ดาวน์โหลดสำเร็จ', 'success');
}
async function exportExcelReport() {
  const month = document.getElementById('exportMonth').value, type = document.getElementById('exportDataType').value;
  showLoading('กำลังสร้างรายงาน...');
  const actionMap = { logs: 'exportReport', schedule: 'getSchedule', stats: 'getStats' };
  const res = await api({ action: actionMap[type]||'exportReport', month }); hideLoading();
  if (!res.data?.length) { toast('ไม่มีข้อมูล', 'error'); return; }
  const ws = XLSX.utils.json_to_sheet(res.data), wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'รายงาน');
  XLSX.writeFile(wb, `รายงาน_${type}_${month}.xlsx`);
  toast('ดาวน์โหลดสำเร็จ', 'success');
}
async function generatePDF() {
  showLoading('กำลังสร้าง PDF...');
  const res = await api({ action: 'exportReport', month: document.getElementById('reportMonth').value });
  hideLoading();
  if (res.status !== 'success') { toast('สร้างรายงานไม่ได้', 'error'); return; }
  const data = res.data||[], preview = document.getElementById('reportPreview'), content = document.getElementById('reportContent');
  preview.style.display = 'block';
  content.innerHTML = `<div style="font-family:'Sarabun',sans-serif;padding:20px;max-width:800px;margin:auto">
    <div style="text-align:center;margin-bottom:24px;border-bottom:3px solid var(--teal);padding-bottom:16px">
      <h2 style="font-family:'Kanit',sans-serif;font-size:20px;color:var(--teal-dark)">รายงานสรุปการเวรบุคลากร</h2>
      <p style="color:var(--gray-600)">สร้างเมื่อ ${new Date().toLocaleDateString('th-TH')}</p>
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:12px">
      <thead><tr style="background:#E0F2F1">${['วันที่','ชื่อบุคลากร','ตำแหน่ง','ประเภทเวร','เข้าเวร','ออกเวร','สถานะ','GPS'].map(h=>`<th style="padding:8px;border:1px solid #ccc;font-weight:700;color:var(--teal-dark)">${h}</th>`).join('')}</tr></thead>
      <tbody>${data.map((r,i)=>`<tr style="background:${i%2?'#fff':'#f9f9f9'}">
        <td style="padding:8px;border:1px solid #eee">${formatDate(r['วันที่'])}</td>
        <td style="padding:8px;border:1px solid #eee">${r['ชื่อบุคลากร']||'-'}</td>
        <td style="padding:8px;border:1px solid #eee">${r['ตำแหน่ง']||'-'}</td>
        <td style="padding:8px;border:1px solid #eee">${r['ประเภทเวร']||'-'}</td>
        <td style="padding:8px;border:1px solid #eee">${formatTime(r['เวลาเข้าเวร'])}</td>
        <td style="padding:8px;border:1px solid #eee">${formatTime(r['เวลาออกเวร'])}</td>
        <td style="padding:8px;border:1px solid #eee">${r['สถานะ']||'-'}</td>
        <td style="padding:8px;border:1px solid #eee;font-size:10px">${r['GPS สถานะ']||'-'}</td>
      </tr>`).join('')}</tbody>
    </table>
    <div style="margin-top:20px;text-align:right;font-size:11px;color:var(--gray-400)">จำนวนทั้งหมด: ${data.length} รายการ</div>
  </div>`;
  preview.scrollIntoView({ behavior: 'smooth' });
  toast('สร้างรายงานสำเร็จ - กดพิมพ์เพื่อบันทึก PDF', 'success');
}
function printReport() {
  const content = document.getElementById('reportContent').innerHTML;
  const w = window.open('','_blank');
  w.document.write(`<html><head><title>รายงานบุคลากรเวร</title><link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;600&display=swap" rel="stylesheet"><style>body{font-family:'Sarabun',sans-serif}@media print{body{margin:0}}</style></head><body>${content}</body></html>`);
  w.document.close(); setTimeout(() => { w.print(); w.close(); }, 1000);
}

/* ═══════════════════════════════════════════════════════════
   SETTINGS
═══════════════════════════════════════════════════════════ */
function saveSettings() {
  const url    = document.getElementById('setScriptUrl').value.trim();
  const name   = document.getElementById('setSchoolName').value.trim();
  const lat    = document.getElementById('setLat').value.trim();
  const lng    = document.getElementById('setLng').value.trim();
  const radius = document.getElementById('setRadius').value.trim();
  const tgToken= document.getElementById('setTgToken').value.trim();
  const tgChat = document.getElementById('setTgChat').value.trim();

  if (!url) { toast('กรุณาใส่ Script URL', 'error'); return; }

  SCRIPT_URL = url;
  GAS_URL = url;
  localStorage.setItem('scriptUrl', url);
  if (name)    { localStorage.setItem('schoolName', name); document.getElementById('schoolNameDisplay').textContent = name; }
  if (lat)       localStorage.setItem('schoolLat',  lat);
  if (lng)       localStorage.setItem('schoolLng',  lng);
  if (radius)    localStorage.setItem('gpsRadius',  radius);
  if (tgToken)   localStorage.setItem('tgToken',    tgToken);
  if (tgChat)    localStorage.setItem('tgChat',     tgChat);

  toast('✅ บันทึกการตั้งค่าสำเร็จ! กำลังเชื่อมต่อ...', 'success');
  document.getElementById('sysStatus').textContent = 'กำลังเชื่อมต่อ...';
  api({ action: 'init' }).then(res => {
    document.getElementById('sysStatus').textContent = res.status === 'success' ? 'ออนไลน์ ✅' : 'เชื่อมต่อไม่ได้';
    if (res.status === 'success') { loadDashboard(); loadTeachers(); }
  });
}

/* ═══════════════════════════════════════════════════════════
   UI HELPERS
═══════════════════════════════════════════════════════════ */
function getStatusBadge(s) {
  const m = { 'เข้าเวรแล้ว':'badge-info','ออกเวรแล้ว':'badge-success','ขาดเวร':'badge-danger','รอเข้าเวร':'badge-warning','ปกติ':'badge-success' };
  return `<span class="badge ${m[s]||'badge-gray'}">${s||'-'}</span>`;
}
function showLoading(msg) {
  const el = document.getElementById('loadingOverlay'); el.style.display = 'flex';
  const t = el.querySelector('.loading-text'); if (t) t.textContent = msg||'กำลังโหลด...';
}
function hideLoading() { document.getElementById('loadingOverlay').style.display = 'none'; }
function toast(msg, type='info') {
  const c = document.getElementById('toastContainer');
  const t = document.createElement('div'); t.className = `toast ${type}`;
  const icons = { success:'fas fa-check-circle', error:'fas fa-times-circle', info:'fas fa-info-circle' };
  const colors = { success:'#43A047', error:'#E53935', info:'var(--teal)' };
  t.innerHTML = `<i class="${icons[type]||icons.info}" style="color:${colors[type]||colors.info};font-size:18px;flex-shrink:0"></i><span style="font-size:14px;font-weight:500">${msg}</span>`;
  c.appendChild(t);
  setTimeout(() => { t.style.animation = 'slideIn .3s ease reverse'; setTimeout(() => t.remove(), 300); }, 3500);
}
</script>
