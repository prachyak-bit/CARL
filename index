═══════════════════════════════════════════════════════════ */
function renderCalendar() {
  updateCalLabel();
  const monthStr = calYear + '-' + String(calMonth+1).padStart(2,'0');
  api({ action: 'getCalendar', month: monthStr }).then(res => {
    buildCalGrid(res.schedule||[], res.logs||[]);
  });
}
function updateCalLabel() {
  document.getElementById('calMonthLabel').textContent =
    new Date(calYear, calMonth).toLocaleDateString('th-TH', { month:'long', year:'numeric' });
}
function buildCalGrid(schedule, logs) {
  const grid = document.getElementById('calendarGrid');
  grid.innerHTML = '';
  const firstDay    = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  const today       = todayStr();
  const prevDays    = new Date(calYear, calMonth, 0).getDate();
  for (let i = firstDay-1; i >= 0; i--) {
    const div = document.createElement('div'); div.className = 'cal-day other-month';
    div.innerHTML = `<div class="day-num">${prevDays-i}</div>`; grid.appendChild(div);
  }
  for (let d = 1; d <= daysInMonth; d++) {
    const dateStr = calYear+'-'+String(calMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const daySched = schedule.filter(s => String(s['วันที่']).substring(0,10) === dateStr);
    const dayLogs  = logs.filter(l => String(l['วันที่']).substring(0,10) === dateStr);
    const div = document.createElement('div');
    div.className = 'cal-day' + (dateStr === today ? ' today' : '');
    div.onclick = () => showCalDay(dateStr, daySched, dayLogs);
    let dots = '';
    if (dayLogs.length) dots += `<span class="duty-dot" style="background:var(--teal)"></span>`;
    if (daySched.length > dayLogs.length) dots += `<span class="duty-dot" style="background:var(--amber)"></span>`;
    div.innerHTML = `<div class="day-num">${d}</div><div style="margin-top:4px">${dots}</div>${daySched.length?`<div style="font-size:9px;color:var(--gray-600);margin-top:2px">${daySched.length}เวร</div>`:''}`;
    grid.appendChild(div);
  }
}
function showCalDay(dateStr, schedule, logs) {
  document.getElementById('calDetailDate').textContent = formatDate(dateStr);
  document.getElementById('calDayDetail').style.display = 'block';
  const c = document.getElementById('calDetailContent');
  if (!schedule.length && !logs.length) { c.innerHTML = '<p style="text-align:center;padding:20px;color:var(--gray-400)">ไม่มีตารางเวรวันนี้</p>'; return; }
  c.innerHTML = `<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
    <div><h4 style="font-size:13px;font-weight:700;color:var(--amber);margin-bottom:10px"><i class="fas fa-calendar"></i> ตารางเวร (${schedule.length})</h4>
      ${schedule.map(s=>`<div style="padding:8px;background:var(--gray-50);border-radius:8px;margin-bottom:6px;font-size:12px"><b>${s['ชื่อบุคลากร']||'-'}</b><br>${s['ประเภทเวร']||''} • ${s['สถานที่เวร']||''}<br><span style="color:var(--teal-dark)">${formatTime(s['เวลาเริ่ม'])} – ${formatTime(s['เวลาสิ้นสุด'])}</span></div>`).join('')||'<p style="font-size:12px;color:var(--gray-400)">ไม่มี</p>'}
    </div>
    <div><h4 style="font-size:13px;font-weight:700;color:var(--teal);margin-bottom:10px"><i class="fas fa-check"></i> บันทึกเข้าเวร (${logs.length})</h4>
      ${logs.map(l=>`<div style="padding:8px;background:var(--teal-pale);border-radius:8px;margin-bottom:6px;font-size:12px"><b>${l['ชื่อบุคลากร']||'-'}</b><br>เข้า ${formatTime(l['เวลาเข้าเวร'])} ออก ${formatTime(l['เวลาออกเวร'])}</div>`).join('')||'<p style="font-size:12px;color:var(--gray-400)">ไม่มี</p>'}
    </div>
  </div>`;
  document.getElementById('calDayDetail').scrollIntoView({ behavior: 'smooth' });
}
function changeCalMonth(delta) {
  calMonth += delta;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  if (calMonth < 0)  { calMonth = 11; calYear--; }
  renderCalendar();
}
