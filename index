function loadLocalSettings() {
  const logo = localStorage.getItem('schoolLogo');
  if (logo) applyLogo(logo);

  const url = localStorage.getItem('scriptUrl') || '';
  if (url) {
    SCRIPT_URL = url;
    const urlInput = document.getElementById('setScriptUrl');
    if (urlInput) urlInput.value = url;
  }

  const name = localStorage.getItem('schoolName') || '';
  if (name) {
    document.getElementById('schoolNameDisplay').textContent = name;
    const ni = document.getElementById('setSchoolName'); if (ni) ni.value = name;
  }
  ['schoolLat:setLat','schoolLng:setLng','gpsRadius:setRadius','tgToken:setTgToken','tgChat:setTgChat'].forEach(pair => {
    const [key, elId] = pair.split(':');
    const v = localStorage.getItem(key); const el = document.getElementById(elId);
    if (v && el) el.value = v;
  });
}

function setDefaultDates() {
  const today = todayStr(), thisMonth = today.substring(0,7);
  const set = (id, v) => { const e = document.getElementById(id); if (e) e.value = v; };
  set('scDate', today); set('logsMonthFilter', thisMonth);
  set('statsMonth', thisMonth); set('reportMonth', thisMonth); set('exportMonth', thisMonth);

  document.getElementById('dashDateDisplay').textContent =
    new Date().toLocaleDateString('th-TH', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

  const select = document.getElementById('scheduleMonthFilter');
  for (let m = 0; m < 12; m++) {
    const d = new Date(new Date().getFullYear(), m, 1);
    const val = d.toISOString().substring(0,7);
    const opt = document.createElement('option');
    opt.value = val;
    opt.textContent = d.toLocaleDateString('th-TH', { month:'long', year:'numeric' });
    select.appendChild(opt);
  }
}

async function loadRemoteConfig() {
  try {
