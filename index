async function saveScheduleRange() {
  const startVal = document.getElementById('scRangeStart').value, endVal = document.getElementById('scRangeEnd').value;
  const name = document.getElementById('scRangeTeacherName').value.trim(), id = document.getElementById('scRangeTeacherId').value.trim();
  if (!startVal) { toast('กรุณาเลือกวันเริ่มต้น', 'error'); return; }
  if (!name) { toast('กรุณากรอกชื่อบุคลากร', 'error'); return; }
  const start = new Date(startVal), end = new Date(endVal || startVal);
  const selDays = [0,1,2,3,4,5,6].filter(i => document.getElementById('dow'+i)?.checked);
  const entries = [];
  for (let d = new Date(start); d <= end; d.setDate(d.getDate()+1)) {
    if (selDays.includes(d.getDay())) {
      entries.push({ date: normalizeDate(new Date(d)), teacherId: id, teacherName: name,
        dutyType: document.getElementById('scRangeDutyType').value,
        location: document.getElementById('scRangeLocation').value,
        startTime: '07:00', endTime: '17:00' });
    }
  }
  if (!entries.length) { toast('ไม่พบวันที่ตรงกับที่เลือก', 'error'); return; }
  if (!confirm(`จะเพิ่มตารางเวร ${entries.length} รายการ ยืนยัน?`)) return;
  showLoading('กำลังบันทึก...');
  const res = await api({ action: 'addSchedule', entries });
  hideLoading();
  if (res.status === 'success') toast(res.message, 'success');
  else toast('เกิดข้อผิดพลาด', 'error');
}
