<script>
/* ═══════════════════════════════════════════════════════════
   CONFIG — แก้ GAS_URL ตรงนี้เท่านั้น
═══════════════════════════════════════════════════════════ */
let GAS_URL = localStorage.getItem('scriptUrl') || '';
let SCRIPT_URL = GAS_URL;

/* ═══════════════════════════════════════════════════════════
   ADMIN AUTH
═══════════════════════════════════════════════════════════ */
let adminToken = sessionStorage.getItem('adminToken') || '';
let _adminCallback = null;

function requireAdmin(callback) {
  if (adminToken) { callback(); return; }
  _adminCallback = callback;
  document.getElementById('adminModal').style.display = 'flex';
  document.getElementById('adminPwdInput').value = '';
  document.getElementById('adminPwdError').style.display = 'none';
  setTimeout(() => document.getElementById('adminPwdInput').focus(), 100);
}

function closeAdminModal() {
  document.getElementById('adminModal').style.display = 'none';
  _adminCallback = null;
}

async function verifyAdminPwd() {
  const pwd = document.getElementById('adminPwdInput').value.trim();
  if (!pwd) return;
  const btn = document.getElementById('adminSubmitBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังตรวจสอบ...';
  btn.disabled = true;

  const res = await api({ action: 'verifyAdmin', password: pwd });

  btn.innerHTML = '<i class="fas fa-unlock"></i> เข้าสู่ระบบ';
  btn.disabled = false;

  if (res.status === 'success') {
    adminToken = res.token || 'ok';
    sessionStorage.setItem('adminToken', adminToken);
    closeAdminModal();
    if (_adminCallback) { _adminCallback(); _adminCallback = null; }
  } else {
    document.getElementById('adminPwdError').style.display = 'block';
    document.getElementById('adminPwdInput').focus();
    document.getElementById('adminPwdInput').select();
  }
}

/* ═══════════════════════════════════════════════════════════
   API HELPER — ใช้ POST JSON เท่านั้น (ไม่ใช้ GET)
═══════════════════════════════════════════════════════════ */
async function api(payload) {
  if (!SCRIPT_URL) {
    toast('❌ กรุณาตั้งค่า Script URL ในหน้าตั้งค่าก่อน', 'error');
    return { status: 'error', message: 'No Script URL configured' };
  }

  const { action } = payload;
  if (!action) {
    console.error('❌ Error: action is missing!', payload);
    return { status: 'error', message: 'No action specified' };
  }

  try {
    console.log('📤 Sending:', action, payload);
    const res = await fetch(SCRIPT_URL, {
      method: 'POST',
      redirect: 'follow',
      headers: { 'Content-Type': 'application/json;charset=utf-8' },
      body: JSON.stringify(payload)
    });

    const text = await res.text();
    console.log('📥 Response:', text.substring(0, 200));

    try {
      const data = JSON.parse(text);
      return data;
    } catch(e) {
      console.error('❌ Parse error:', text);
      return { status: 'error', message: 'Invalid JSON response: ' + text.substring(0, 100) };
    }
  } catch (e) {
    console.error('❌ Fetch error:', e);
    toast('❌ เชื่อมต่อ GAS ไม่ได้: ' + e.message, 'error');
    return { status: 'error', message: e.message };
  }
}

/* ═══════════════════════════════════════════════════════════
   DATE / TIME HELPERS
═══════════════════════════════════════════════════════════ */
function todayStr() {
  const n = new Date();
  return n.getFullYear() + '-' + String(n.getMonth()+1).padStart(2,'0') + '-' + String(n.getDate()).padStart(2,'0');
}
function formatDate(v) {
  if (!v) return '-';
  const s = String(v).substring(0,10);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(s)) return v;
  const [y,m,d] = s.split('-');
  return `${d}/${m}/${y}`;
}
function formatTime(v) {
  if (!v || v === '-') return '-';
  const s = String(v).trim();
  if (/^\d{1,2}:\d{2}/.test(s)) return s.substring(0,5);
  if (s.includes('T')) {
    try { const d=new Date(s); return String(d.getUTCHours()).padStart(2,'0')+':'+String(d.getUTCMinutes()).padStart(2,'0'); }
    catch(e){}
  }
  return s;
}
function normalizeDate(v) {
  if (!v) return '';
  if (v instanceof Date) return v.getFullYear()+'-'+String(v.getMonth()+1).padStart(2,'0')+'-'+String(v.getDate()).padStart(2,'0');
  const s = String(v).trim();
  if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
  if (/^\d{4}-\d{2}-\d{2}T/.test(s)) return s.substring(0,10);
  return s;
}

/* ═══════════════════════════════════════════════════════════
   CAMERA
═══════════════════════════════════════════════════════════ */
let camStream = null;
let camFacing = 'environment';

async function openCameraModal() {
  document.getElementById('cameraModal').classList.add('open');
  await startCamStream();
}
async function startCamStream() {
  if (camStream) { camStream.getTracks().forEach(t => t.stop()); camStream = null; }
  try {
    camStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: camFacing, width: { ideal: 1280 }, height: { ideal: 720 } },
      audio: false
    });
    document.getElementById('camVideo').srcObject = camStream;
    document.getElementById('camFacingLabel').textContent = camFacing === 'environment' ? '(กล้องหลัง)' : '(กล้องหน้า)';
  } catch (e) {
    toast('ไม่สามารถเปิดกล้องได้: ' + e.message, 'error');
    closeCameraModal();
    document.getElementById('photoFileInput').click();
  }
}
async function switchCamera() {
  camFacing = camFacing === 'environment' ? 'user' : 'environment';
  await startCamStream();
}
function captureFromCamera() {
  const video = document.getElementById('camVideo');
  const canvas = document.getElementById('camCanvas');
  canvas.width = video.videoWidth || 640;
  canvas.height = video.videoHeight || 480;
  canvas.getContext('2d').drawImage(video, 0, 0);
  setPhotoPreview(canvas.toDataURL('image/jpeg', 0.85));
  closeCameraModal();
  toast('ถ่ายรูปสำเร็จ ✅', 'success');
}
function closeCameraModal() {
  if (camStream) { camStream.getTracks().forEach(t => t.stop()); camStream = null; }
  document.getElementById('cameraModal').classList.remove('open');
}
function handleFileSelect(e) {
  const file = e.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => { setPhotoPreview(ev.target.result); toast('เลือกรูปสำเร็จ ✅', 'success'); };
  reader.readAsDataURL(file);
}
function setPhotoPreview(dataUrl) {
  document.getElementById('ciPhotoBase64').value = dataUrl;
  const img = document.getElementById('photoPreview');
  img.src = dataUrl;
  document.getElementById('photoBox').classList.add('has-photo');
}
function clearPhoto() {
  document.getElementById('ciPhotoBase64').value = '';
  document.getElementById('photoPreview').src = '';
  document.getElementById('photoBox').classList.remove('has-photo');
}

/* ═══════════════════════════════════════════════════════════
   GPS
═══════════════════════════════════════════════════════════ */
function getGPS() {
  const statusEl = document.getElementById('gpsStatusText');
  const coordEl  = document.getElementById('gpsCoordText');
  statusEl.textContent = '⏳ กำลังรับตำแหน่ง...';
  if (!navigator.geolocation) { statusEl.textContent = '❌ ไม่รองรับ GPS'; return; }
  navigator.geolocation.getCurrentPosition(pos => {
    const { latitude: lat, longitude: lng, accuracy: acc } = pos.coords;
    document.getElementById('ciLat').value = lat;
    document.getElementById('ciLng').value = lng;
    statusEl.textContent = '✅ ได้รับตำแหน่งแล้ว';
    coordEl.textContent  = `${lat.toFixed(5)}, ${lng.toFixed(5)} ±${Math.round(acc)}ม.`;
    const card = document.getElementById('gpsCard');
    card.style.background = 'linear-gradient(135deg,#E8F5E9,#C8E6C9)';
